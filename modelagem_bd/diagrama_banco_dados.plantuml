@startuml Diagrama de Banco de Dados - Sistema de Demandas
!theme plain

hide circle
hide methods
hide stereotypes
skinparam linetype ortho

title Diagrama de Banco de Dados - Sistema de Demandas

entity "usuarios" as usuarios {
  *id : integer <<PK>>
  --
  nome_completo : varchar
  email : varchar <<UNIQUE>>
  senha_hash : varchar
  nivel_permissao : varchar
  ativo : boolean
  criado_em : timestamp
  ultimo_acesso : timestamp
  senha_temporaria : boolean
  cpf : varchar <<UNIQUE>>
  telefone : varchar <<UNIQUE>>
  data_nascimento : date
}

entity "cidadaos" as cidadaos {
  *id : integer <<PK>>
  --
  nome_completo : varchar
  telefone : varchar <<UNIQUE>>
  data_nascimento : date
  bairro : varchar
  cidade : varchar
  estado : varchar
  email : varchar
  criado_em : timestamp
}

entity "status" as status {
  *id : integer <<PK>>
  --
  nome : varchar
  ordem : integer
  ativo : boolean
  criado_em : timestamp
}

entity "demandas" as demandas {
  *id : integer <<PK>>
  --
  titulo : varchar
  descricao : text
  prioridade : varchar
  cidadao_id : integer <<FK>>
  usuario_responsavel_id : integer <<FK>>
  usuario_origem_id : integer <<FK>>
  status_id : integer <<FK>>
  criado_em : timestamp
  atualizado_em : timestamp
}

entity "arquivos" as arquivos {
  *id : integer <<PK>>
  --
  demanda_id : integer <<FK>>
  nome_arquivo : varchar
  tipo_arquivo : varchar
  caminho_arquivo : varchar
  tamanho_arquivo : integer
  criado_em : timestamp
}

entity "comentarios" as comentarios {
  *id : integer <<PK>>
  --
  demanda_id : integer <<FK>>
  usuario_id : integer <<FK>>
  comentario : text
  criado_em : timestamp
  publico : boolean
}

entity "eventos" as eventos {
  *id : integer <<PK>>
  --
  nome : varchar
  descricao : text
  data_evento : timestamp
  local : varchar
  ativo : boolean
  criado_em : timestamp
  criado_por : integer <<FK>>
  atualizado_em : timestamp
}

entity "lista_presenca" as lista_presenca {
  *id : integer <<PK>>
  --
  evento_id : integer <<FK>>
  nome_completo : varchar
  telefone : varchar
  email : varchar
  observacoes : text
  criado_em : timestamp
  criado_por : integer <<FK>>
  atualizado_em : timestamp
}

' === RELAÇÕES ===
cidadaos ||--o{ demandas : "possui"
usuarios ||--o{ demandas : "origina"
usuarios ||--o{ demandas : "responsável por"
status ||--o{ demandas : "define status"
demandas ||--o{ arquivos : "possui"
demandas ||--o{ comentarios : "contém"
usuarios ||--o{ comentarios : "escreve"
usuarios ||--o{ eventos : "cria"
eventos ||--o{ lista_presenca : "tem"
usuarios ||--o{ lista_presenca : "registra"

@enduml